{
  "name": "iphone-wallpaper-maker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check && pnpm lint",
    "pre-push": "pnpm test"
  },
  "pnpm": {
    "overrides": {
      "@rollup/plugin-terser": "1.0.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@kayahr/stackblur": "^2.0.1",
    "heic-to": "^1.4.2",
    "pica": "^9.0.1"
  }
}
